---
import Layout from '../layouts/Layout.astro';

// Fetch pinned repos
let projects: any[] = [];
try {
  const pinnedRes = await fetch('https://pinned.berrysauce.dev/get/roerohan');
  if (pinnedRes.ok) {
    projects = await pinnedRes.json();
  }
} catch {}

if (!projects.length) {
  try {
    const ghRes = await fetch('https://api.github.com/users/roerohan/repos?sort=updated&per_page=6');
    if (ghRes.ok) {
      const repos = await ghRes.json();
      projects = repos.map((r: any) => ({
        name: r.name,
        description: r.description,
        language: r.language,
        topics: r.topics?.slice(0, 3) || [],
        html_url: r.html_url,
        homepage: r.homepage,
      }));
    }
  } catch {}
}

// Fetch blog posts
let blogPosts: any[] = [];
try {
  const blogRes = await fetch('https://blog.roerohan.com/page-data/index/page-data.json');
  if (blogRes.ok) {
    const blogData = await blogRes.json();
    const nodes = blogData?.result?.data?.allMarkdownRemark?.nodes || [];
    blogPosts = nodes.slice(0, 5).map((node: any) => ({
      title: node.frontmatter?.title,
      date: node.frontmatter?.date,
      description: node.frontmatter?.description || '',
      excerpt: node.excerpt,
      slug: node.fields?.slug,
    }));
  }
} catch {}

if (!blogPosts.length) {
  blogPosts = [
    {
      title: 'The setup that keeps me sane as a developer',
      date: 'April 04, 2025',
      description: 'My carefully optimized (and slightly over-engineered) development environment.',
      excerpt: "I have a borderline obsession with good dev setups. The right tools don't just make me faster, they keep me from slowly losing my mind. This...",
      slug: '/the-setup-that-keeps-me-sane-as-a-developer/',
    },
    {
      title: 'How to Protect Yourself Online',
      date: 'March 03, 2024',
      description: "A narrative about how my friend fell for one of the most elaborate scams I've seen recently.",
      excerpt: 'Even the most intelligent individuals may find themselves outsmarted under stress, as the pressure of the moment can cloud judgment and...',
      slug: '/how-to-protect-yourself-online/',
    },
    {
      title: 'Type fast, and master your text editor',
      date: 'October 25, 2023',
      description: 'Working online often requires writing and editing text. Learn to type fast, and master a text editor of your choice.',
      excerpt: "Whether you're a software developer or a technical writer, your primary job is to edit text. It is surprising that most people whose jobs...",
      slug: '/type-fast-and-master-your-text-editor/',
    },
  ];
}
---

<Layout title="Rohan Mukherjee | Portfolio" description="Software Engineer at Cloudflare, ex-founding engineer at Dyte (YC W'21), open source contributor, and cybersecurity enthusiast.">

  <!-- Hero -->
  <section style="padding-top: 4rem; padding-bottom: 5rem; border-bottom: 1px solid var(--border);">
    <a href="/freelance" class="badge badge--accent" style="margin-bottom: 1.5rem;">
      <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--ink); display: inline-block;"></span>
      Available for freelance
    </a>
    <h1 style="font-size: clamp(2rem, 5vw, 3rem); letter-spacing: -0.02em; margin-bottom: 1rem;">
      Yet Another<br/>
      <em style="font-style: italic;">Portfolio Website</em>
    </h1>
    <p style="font-size: 1.125rem; color: var(--muted); max-width: 540px; line-height: 1.7;">
      You've reached the internet's 134013489908th attempt at a portfolio website. Hey! I'm a software engineer at Cloudflare, and an ex-founding engineer at Dyte (YC W'21).
    </p>
    <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.75rem;">
      <a href="/freelance" class="btn btn--primary">Work with me</a>
      <a href="#contact" class="btn">Get in touch</a>
      <a href="#projects" class="btn">View projects</a>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="section">
    <h2 class="section-label">About Me</h2>
    <div style="display: flex; flex-direction: column; gap: 0;" class="prose">
      <p>Hi! I'm Rohan.</p>
      <p>
        I'm passionate about building tools and products with taste. Crafting things that are thoughtful and well-made, not just AI-generated slop. AI has unlocked incredible leverage, and I think the bar for what we ship should be higher, not lower.
      </p>
      <p>
        I work at <a href="https://cloudflare.com">Cloudflare</a>, contribute to <a href="https://github.com/roerohan">open source</a>, and <a href="/freelance">freelance</a> on the side. Previously, I was a founding engineer at <a href="https://dyte.io">Dyte</a> (YC W'21), which is now part of Cloudflare as the <a href="https://realtime.cloudflare.com">Realtime Kit</a>.
      </p>
    </div>
    <div class="grid-2" style="margin-top: 2rem;">
      <div class="card">
        <h3 style="font-size: 1rem; margin-bottom: 0.5rem;">Building</h3>
        <p style="font-size: 0.9375rem; color: var(--muted); line-height: 1.6;">
          I care about shipping products that are well-crafted — good defaults, clean interfaces, honest engineering. I build <a href="https://github.com/roerohan">open source tools</a>, contribute to developer infrastructure, and <a href="https://blog.roerohan.com">write about the process</a>.
        </p>
      </div>
      <div class="card">
        <h3 style="font-size: 1rem; margin-bottom: 0.5rem;">Security</h3>
        <p style="font-size: 0.9375rem; color: var(--muted); line-height: 1.6;">
          A background in <a href="https://github.com/roerohan/CTF-Write-ups">CTFs and penetration testing</a> that still shapes how I think about systems. Security isn't my day job anymore, but it's always in the back of my mind.
        </p>
      </div>
      <div class="card">
        <h3 style="font-size: 1rem; margin-bottom: 0.5rem;">Off-screen</h3>
        <p style="font-size: 0.9375rem; color: var(--muted); line-height: 1.6;">
          I'll say yes to pretty much any outdoor activity — mostly climbing and playing football. Indoors, I'm usually playing guitar or <a href="https://spotify.link/OCbg4u8UWDb">finding new music</a>.
        </p>
      </div>
      <div class="card">
        <h3 style="font-size: 1rem; margin-bottom: 0.5rem;">Tech Stack</h3>
        <p style="font-size: 0.9375rem; color: var(--muted); line-height: 1.6; margin-bottom: 0.75rem;">
          Whatever gets the job done well. I'm most at home with:
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.375rem;">
          {['TypeScript', 'Go', 'Cloudflare Workers', 'React', 'Node.js', 'WebRTC', 'Docker', 'Kubernetes'].map(t => (
            <span class="tag">{t}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Experience -->
  <section id="experience" class="section">
    <h2 class="section-label">Work Experience</h2>
    <div>
      <div class="timeline-item-link">
        <div class="timeline-item">
          <div class="timeline-header">
            <h3 class="timeline-title"><a href="https://www.linkedin.com/company/cloudflare" target="_blank" rel="noopener noreferrer">Engineer <span class="muted" style="font-weight: 400;">— Cloudflare</span></a></h3>
            <span class="timeline-period">2025 - Present</span>
          </div>
          <p class="timeline-desc">I'm part of Cloudflare's Emerging Technology and Incubation team — basically a startup that gets to break things at internet scale. We take moonshots and build what the internet looks like next. I've shipped <a href="https://realtime.cloudflare.com" target="_blank" rel="noopener noreferrer">Realtime Kit</a> for real-time communication on the edge, contributed to <a href="https://developers.cloudflare.com/ai-gateway/" target="_blank" rel="noopener noreferrer">AI Gateway</a> for managing AI inference at scale, and whatever else they let me loose on.</p>
          <div class="timeline-tags">
            {['TypeScript', 'Go', 'Edge Computing', 'WebRTC'].map(t => <span class="tag">{t}</span>)}
          </div>
        </div>
      </div>
      <a href="https://www.linkedin.com/company/dyteio" target="_blank" rel="noopener noreferrer" class="timeline-item-link">
        <div class="timeline-item">
          <div class="timeline-header">
            <h3 class="timeline-title">Founding Engineer <span class="muted" style="font-weight: 400;">— Dyte (now Cloudflare)</span></h3>
            <span class="timeline-period">2020 - 2025</span>
          </div>
          <p class="timeline-desc">Embarked on an incredible journey from a college project to a 50+ member company that eventually joined Cloudflare. Contributed to all aspects of the technology, most notably architecting and building the core SDK.</p>
          <div class="timeline-tags">
            {['WebRTC', 'TypeScript', 'Go', 'System Administration', 'Kubernetes'].map(t => <span class="tag">{t}</span>)}
          </div>
        </div>
      </a>
      <a href="/freelance" class="timeline-item-link">
        <div class="timeline-item">
          <div class="timeline-header">
            <h3 class="timeline-title">Freelance Developer</h3>
            <span class="timeline-period">2019 - Present</span>
          </div>
          <p class="timeline-desc">Offering full-stack development, content writing, programming tutoring, and penetration testing services to clients worldwide.</p>
          <div class="timeline-tags">
            {['Full-stack', 'Content Writing', 'Tutoring', 'Penetration Testing'].map(t => <span class="tag">{t}</span>)}
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects" class="section">
    <h2 class="section-label">Projects</h2>

    <!-- Things I'm Building -->
    <h3 style="font-family: var(--font-serif); font-size: 1.25rem; margin-bottom: 1.25rem;">Shipping</h3>
    <div class="grid-2" style="margin-bottom: 2.5rem;">
      <a href="https://pullsmith.roerohan.com" target="_blank" rel="noopener noreferrer" class="card" style="text-decoration: none; color: inherit; display: block;">
        <h4 style="font-size: 1rem; margin-bottom: 0.375rem;">Pullsmith</h4>
        <p style="font-size: 0.875rem; color: var(--muted); line-height: 1.5;">
          Ship code from your phone. Chat with any AI model, make quick edits, and open pull requests — from any device, no dev setup needed.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.375rem; margin-top: 0.75rem;">
          {['Cloudflare Workers', 'AI', 'Mobile-first'].map(t => <span class="tag" style="font-size: 0.75rem; padding: 0.125rem 0.5rem;">{t}</span>)}
        </div>
      </a>
      <a href="https://sidekick.roerohan.com" target="_blank" rel="noopener noreferrer" class="card" style="text-decoration: none; color: inherit; display: block;">
        <h4 style="font-size: 1rem; margin-bottom: 0.375rem;">Sidekick</h4>
        <p style="font-size: 0.875rem; color: var(--muted); line-height: 1.5;">
          LLM chat in your menu bar. BYOK, switch between GPT, Claude, Gemini and more. Share your screen for visual context.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 0.375rem; margin-top: 0.75rem;">
          {['macOS', 'AI', 'Desktop App'].map(t => <span class="tag" style="font-size: 0.75rem; padding: 0.125rem 0.5rem;">{t}</span>)}
        </div>
      </a>
    </div>

    <!-- Open Source -->
    <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 1.25rem;">
      <h3 style="font-family: var(--font-serif); font-size: 1.25rem;">Open Source</h3>
      <a href="https://github.com/roerohan" target="_blank" rel="noopener noreferrer" style="font-size: 0.875rem;">View all on GitHub &rarr;</a>
    </div>
    {projects.length > 0 ? (
      <div class="grid-3">
        {projects.map((repo: any) => (
          <a href={repo.html_url || `https://github.com/roerohan/${repo.name}`} target="_blank" rel="noopener noreferrer" class="card" style="text-decoration: none; color: inherit; display: block;">
            <h4 style="font-size: 1rem; margin-bottom: 0.375rem;">{repo.name}</h4>
            <p style="font-size: 0.875rem; color: var(--muted); line-height: 1.5; margin-bottom: 0.5rem;">
              {repo.description || 'No description provided.'}
            </p>
            <div class="project-meta">
              {repo.language && (
                <span class="project-language">
                  <span class="dot" style="background: var(--muted);"></span>
                  {repo.language}
                </span>
              )}
            </div>
            {(repo.topics?.length > 0) && (
              <div style="display: flex; flex-wrap: wrap; gap: 0.25rem; margin-top: 0.5rem;">
                {repo.topics.slice(0, 3).map((topic: string) => (
                  <span class="tag" style="font-size: 0.75rem; padding: 0.125rem 0.5rem;">{topic}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    ) : (
      <p style="color: var(--muted);">Unable to load projects at this time.</p>
    )}
  </section>

  <!-- Blog -->
  <section id="blog" class="section">
    <div style="display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 2.5rem;">
      <h2 class="section-label" style="margin-bottom: 0;">Writing</h2>
      <a href="/blog" style="font-size: 0.875rem;">View all posts &rarr;</a>
    </div>
    <div class="blog-list">
      {blogPosts.map((post: any) => (
        <article class="blog-list-item">
          <a href={`/blog${post.slug}`} style="text-decoration: none; color: inherit; display: block;">
            <h3 class="blog-list-title">{post.title}</h3>
            <p class="blog-list-meta">{post.date}{post.description && ` — ${post.description}`}</p>
            <p class="blog-list-excerpt">{post.excerpt}</p>
          </a>
        </article>
      ))}
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="section" style="border-bottom: none;">
    <h2 class="section-label">Get in touch</h2>
    <p style="color: var(--muted); margin-bottom: 1.5rem;">
      I'm always open to discussing new projects, opportunities, or collaborations.
    </p>
    <p style="margin-bottom: 2rem;">
      <a href="mailto:me@roerohan.com">me@roerohan.com</a>
    </p>

    <div class="social-links" style="margin-bottom: 2rem;">
      <a href="https://x.com/roerohan" target="_blank" rel="noopener noreferrer" title="X">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a href="https://www.linkedin.com/in/roerohan" target="_blank" rel="noopener noreferrer" title="LinkedIn">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <a href="https://github.com/roerohan" target="_blank" rel="noopener noreferrer" title="GitHub">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
      </a>
      <a href="https://stackoverflow.com/users/11500806/" target="_blank" rel="noopener noreferrer" title="StackOverflow">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M15.725 0l-1.72 1.277 6.39 8.588 1.72-1.277L15.725 0zm-3.94 3.418l-1.369 1.644 8.225 6.85 1.369-1.644-8.225-6.85zm-3.15 4.465l-.905 1.94 9.702 4.517.905-1.94-9.702-4.517zm-1.85 4.86l-.44 2.093 10.473 2.201.44-2.092-10.473-2.203zM1.89 15.47V24h19.19v-8.53h-2.133v6.397H4.021v-6.396H1.89zm4.265 2.254v2.133h10.66v-2.133H6.154z"/></svg>
      </a>
      <a href="https://medium.com/@roerohan" target="_blank" rel="noopener noreferrer" title="Medium">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>
      </a>
      <a href="mailto:roerohan@gmail.com" title="Email">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
      </a>
    </div>

    <form id="contact-form" style="max-width: 480px;">
      <div class="form-group">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" placeholder="Your name" required />
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" placeholder="your.email@example.com" required />
      </div>
      <div class="form-group">
        <label for="message">Message</label>
        <textarea id="message" name="message" placeholder="Your message..." required></textarea>
      </div>
      <button type="submit" class="btn btn--primary" id="submit-btn">Send Message</button>
    </form>
    <div id="success-msg" style="display: none; margin-top: 1rem;">
      <h3 style="font-size: 1.125rem; margin-bottom: 0.375rem;">Message sent!</h3>
      <p style="color: var(--muted); margin-bottom: 0.75rem;">Thanks for reaching out. I'll get back to you soon.</p>
      <button class="btn" id="send-another">Send another message</button>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const successMsg = document.getElementById('success-msg')!;
    const submitBtn = document.getElementById('submit-btn')!;
    const sendAnother = document.getElementById('send-another')!;

    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      submitBtn.textContent = 'Sending...';
      submitBtn.setAttribute('disabled', 'true');
      // TODO: Wire to real backend (Resend, SendGrid, etc.)
      setTimeout(() => {
        form.style.display = 'none';
        successMsg.style.display = 'block';
        submitBtn.textContent = 'Send Message';
        submitBtn.removeAttribute('disabled');
      }, 1000);
    });

    sendAnother?.addEventListener('click', () => {
      form.reset();
      form.style.display = 'block';
      successMsg.style.display = 'none';
    });
  </script>
</Layout>
